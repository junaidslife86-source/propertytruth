# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PropertyTruth

# Supabase (property scan / saved properties)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Address autocomplete & geocoding (server-side)
ADDRESSFINDER_API_KEY=
ADDRESSFINDER_SECRET_KEY=
GOOGLE_PLACES_API_KEY=

# AI summaries (Gemini)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest

# Google Document AI (strata PDF extraction)
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_LOCATION=australia-southeast1

# Firebase (strata uploads, inspections cloud sync)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Path to service account JSON (local dev only — file is gitignored)
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json
# Vercel/production: paste the full service account JSON as one line:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Alternative: inline admin credentials
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY=

# Internal secret for background strata processing (required in production)
INTERNAL_PROCESS_SECRET=

# Maps
NEXT_PUBLIC_MAPLIBRE_STYLE_URL=https://demotiles.maplibre.org/style.json
NEXT_PUBLIC_MAPTILER_API_KEY=

# Scan defaults
DEFAULT_SCAN_RADIUS_METERS=500

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
